generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  excerpt     String
  description String
  images      Json     @default("[]")
  price       Int
  oldPrice    Int?
  brand       String?
  category    String?
  stock       Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String?
  password String
  admin    Boolean @default(false)
}

model Order {
  id        Int @id @default(autoincrement())
  items     String
  amount    Int
  createdAt DateTime @default(now())
}
